<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="HomeMaster.master.cs" Inherits="CapaPresentacion.HomeMaster" %>

<!DOCTYPE html>

<html lang="es">

<head>
    <meta charset="utf-8">
    <title>Librería CONAVI - Tu librería de confianza en Riberalta</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="librería, papelería, útiles escolares, materiales de oficina, Riberalta, CONAVI, cuadernos, libros" name="keywords">
    <meta content="Librería CONAVI - La librería más completa de Riberalta. Materiales escolares, de oficina, accesorios, manualidades, productos personalizados, libros y servicios complementarios." name="description">

    <!-- Favicon -->
    <link href="img/logo.png" rel="icon">

    <!-- Open Graph para redes sociales -->
    <meta property="og:title" content="Librería CONAVI" />
    <meta property="og:description" content="La librería más completa de Riberalta. Materiales escolares, de oficina y accesorios." />

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="lib/animate/animate.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="css/style.css" rel="stylesheet">
    <link href="css/chatbot.css" rel="stylesheet">

    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
</head>

<body>
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner"></div>
    </div>
    <!-- Spinner End -->


    <!-- Topbar Start -->
