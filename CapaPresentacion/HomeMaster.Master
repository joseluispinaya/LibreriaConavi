            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Alternar menú de navegación">
                <span class="fa fa-bars"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarCollapse" role="navigation">
                <div class="navbar-nav ms-auto py-0">
                    <a href="Inicio.aspx" class="nav-item nav-link">Inicio</a>
                    <a href="Nosotros.aspx" class="nav-item nav-link">Nosotros</a>
                    <a href="Productos.aspx" class="nav-item nav-link">Productos</a>
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Catálogo</a>
                        <div class="dropdown-menu m-0">
                            <a href="Productos.aspx" class="dropdown-item">Materiales Escolares</a>
                            <a href="Productos.aspx" class="dropdown-item">Materiales de Oficina</a>
                            <a href="Productos.aspx" class="dropdown-item">Arte y Diseño</a>
                            <a href="Productos.aspx" class="dropdown-item">Libros y Textos</a>
                        </div>
                    </div>
                    <a href="Contactos.aspx" class="nav-item nav-link">Contacto</a>
                </div>
                <a href="https://wa.me/59177464847?text=Hola%20Librería%20CONAVI,%20me%20gustaría%20hacer%20un%20pedido" class="btn btn-secondary py-2 px-4 mt-3 mt-lg-0 ms-lg-3 d-inline-flex align-items-center">Hacer Pedido <img src="img/logo_whatsapp.png" alt="WhatsApp" style="height: 24px;" class="ms-2"></a>
            </div>
        </nav>

        <asp:ContentPlaceHolder ID="titulo" runat="server">
        </asp:ContentPlaceHolder>
    </div>
    <!-- Navbar & Carousel End -->

    <asp:ContentPlaceHolder ID="body" runat="server">
    </asp:ContentPlaceHolder>

