                            </div>
                            <div class="d-flex mb-2">
                                <i class="bi bi-geo-alt text-primary me-2"></i>
                                <p class="mb-0">Riberalta, Beni, Bolivia</p>
                            </div>
                            <div class="d-flex mb-2">
                                <i class="bi bi-envelope-open text-primary me-2"></i>
                                <p class="mb-0">libreriaconavi@gmail.com</p>
                            </div>
                            <div class="d-flex mb-2">
                                <i class="bi bi-telephone text-primary me-2"></i>
                                <p class="mb-0">+591 77464847</p>
                            </div>
                            <div class="d-flex mt-4">
                                <a class="btn btn-primary btn-square me-2" href="https://www.facebook.com/profile.php?id=61574306237458&locale=es_LA" target="_blank"><i class="fab fa-facebook-f fw-normal"></i></a>
                                <a class="btn btn-primary btn-square me-2" href="https://www.instagram.com/libreriaconavi" target="_blank"><i class="fab fa-instagram fw-normal"></i></a>
                                <a class="btn btn-primary btn-square me-2" href="https://wa.me/59177464847" target="_blank"><i class="fab fa-whatsapp fw-normal"></i></a>
                                <a class="btn btn-primary btn-square" href="https://www.tiktok.com/@libreriaconavi" target="_blank"><i class="fab fa-tiktok fw-normal"></i></a>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-12 pt-0 pt-lg-5 mb-5">
                            <div class="section-title section-title-sm position-relative pb-3 mb-4">
                                <h3 class="text-light mb-0">Enlaces Rápidos</h3>
                            </div>
                            <div class="link-animated d-flex flex-column justify-content-start">
                                <a class="text-light mb-2" href="Inicio.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Inicio</a>
                                <a class="text-light mb-2" href="Nosotros.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Nosotros</a>
                                <a class="text-light mb-2" href="Productos.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Productos</a>
                                <a class="text-light" href="Contactos.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Contacto</a>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-12 pt-0 pt-lg-5 mb-5">
                            <div class="section-title section-title-sm position-relative pb-3 mb-4">
                                <h3 class="text-light mb-0">Nuestros Servicios</h3>
                            </div>
                            <div class="link-animated d-flex flex-column justify-content-start">
                                <a class="text-light mb-2" href="Productos.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Impresiones</a>
                                <a class="text-light mb-2" href="Productos.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Fotocopias</a>
                                <a class="text-light mb-2" href="Productos.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Anillado</a>
                                <a class="text-light" href="Productos.aspx"><i class="bi bi-arrow-right text-primary me-2"></i>Plastificado</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid text-white" style="background: #061429;">
        <div class="container text-center">
            <div class="row justify-content-end">
                <div class="col-lg-8 col-md-6">
                    <div class="d-flex align-items-center justify-content-center" style="height: 75px;">
                        <p class="mb-0">&copy; <a class="text-white border-bottom" href="#">Librería CONAVI</a>. Todos los derechos reservados. Riberalta, Bolivia.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->

    <div class="chatbot-window shadow-lg" id="chatbotWindow">

        <div class="chatbot-header bg-primary text-white d-flex justify-content-between align-items-center p-3">
            <h6 class="m-0 fw-bold text-white"><i class="fas fa-robot me-2"></i>Asistente Virtual</h6>
            <button type="button" class="btn-close btn-close-white" id="btnCloseChat" aria-label="Close"></button>
        </div>

        <div class="chatbot-body p-3" id="chatbotBody">
            <div class="chat-message bot-message mb-3">
                <div class="message-content bg-white text-dark p-2 border shadow-sm">¡Hola! 👋 ¿En qué puedo ayudarte hoy?</div>
            </div>
        </div>

        <div class="chatbot-footer p-2 bg-light border-top d-flex align-items-center">
            <input type="text" id="txtChatInput" class="form-control form-control-sm me-2" placeholder="Escribe un mensaje..." autocomplete="off">
            <button type="button" id="btnSendChat" class="btn btn-primary btn-sm rounded-circle shadow-sm" style="width: 35px; height: 35px; padding: 0;">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>

    <a href="#" class="chatbotbtn-float" id="btnOpenChat" title="Chatea con nuestro Bot">
        <img src="img/chat.png" alt="Chatbot" style="width: 100%; height: 100%; object-fit: contain;">
    </a>



    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="lib/wow/wow.min.js"></script>
    <script src="lib/easing/easing.min.js"></script>
    <script src="lib/waypoints/waypoints.min.js"></script>
    <script src="lib/counterup/counterup.min.js"></script>
    <script src="lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Javascript -->
    <script src="js/main.js"></script>
    <script src="js/Masterpa.js?v=<%= DateTime.Now.ToString("yyyyMMddHHmmss") %>" type="text/javascript"></script>
    <asp:ContentPlaceHolder ID="footer" runat="server"></asp:ContentPlaceHolder>
</body>

</html>
